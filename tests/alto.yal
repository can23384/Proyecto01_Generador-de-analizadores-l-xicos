let consonante = ['a'-'z'] # "aeiou"
let number = ['0'-'9']+
let id = ['a'-'z''A'-'Z'](['a'-'z''A'-'Z''0'-'9''_'])*
let ws = [' ''\t''\n']+

rule tokens =
  "if"        { return IF }
| "then"      { return THEN }
| "else"      { return ELSE }
| ":="        { return ASSIGN }
| '\+'        { return PLUS }
| number      { return NUMBER }
| consonante+ { return CONS }
| id          { return ID }
| ws          { /* skip */ }
| eof         { return EOF }